# Copy to .env.local and fill in from your Supabase project settings (Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Web Push — generate a pair with: npx web-push generate-vapid-keys
# The PUBLIC key is safe in the client bundle. The PRIVATE key is a server
# secret — set it (plus the ones below) in Vercel env, never in this client app:
#   VAPID_PRIVATE_KEY          (pairs with the public key; used by api/send-digest)
#   CRON_SECRET                (Vercel Cron sends it as a Bearer token)
#   SUPABASE_SERVICE_ROLE_KEY  (lets the digest read every household; bypasses RLS)
VITE_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
