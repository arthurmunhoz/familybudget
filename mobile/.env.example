# Copy to .env.local (gitignored) and fill in. The anon key is the publishable
# Supabase key — safe in a client. Dev creds sign into the seeded test household
# (temporary, until Google OAuth + Sign in with Apple land).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_DEV_EMAIL=dev@example.com
EXPO_PUBLIC_DEV_PASSWORD=your-dev-password
EXPO_PUBLIC_API_BASE=https://one-roof-app.vercel.app
