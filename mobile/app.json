{
  "expo": {
    "name": "One Roof",
    "slug": "one-roof",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "oneroof",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.oneroof.app",
      "appleTeamId": "R87YC3Q5W2",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.oneroof.app"
        ]
      },
      "infoPlist": {
        "NSFaceIDUsageDescription": "Face ID unlocks your private Document Vault.",
        "NSCameraUsageDescription": "Take photos to scan receipts and bills, and add pet and profile photos.",
        "NSPhotoLibraryUsageDescription": "Attach photos for receipts, pets, profiles and documents.",
        "NSCalendarsUsageDescription": "Add your One Roof events to the device calendar.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.oneroof.app",
      "adaptiveIcon": {
        "backgroundColor": "#fbf6f0",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#fbf6f0",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120,
          "dark": {
            "backgroundColor": "#1b1714"
          }
        }
      ],
      "expo-localization",
      "@react-native-community/datetimepicker",
      "expo-apple-authentication",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Face ID unlocks your private Document Vault."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Attach photos for receipts, pets, profiles and documents.",
          "cameraPermission": "Take photos to scan receipts and bills, and add pet and profile photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#c2603f"
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "One Roof syncs your family calendar with your device calendar."
        }
      ],
      "@bacons/apple-targets"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "643b1295-f7d6-4228-8b92-277790bedd16"
      }
    },
    "owner": "arthurmunhoz"
  }
}
